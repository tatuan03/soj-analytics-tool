# Sao chép file này thành ".env" và chỉnh lại giá trị thật trước khi chạy.
# LƯU Ý: KHÔNG commit file .env thật lên git.

# ---- Môi trường: development | staging | production ----
ENVIRONMENT=development

# ---- Database ----
DATABASE_URL=sqlite:///./game_analytics.db

# ---- JWT ----
# Tạo key ngẫu nhiên bằng: python -c "import secrets; print(secrets.token_hex(32))"
# Ở production BẮT BUỘC đặt key thật >= 32 ký tự, nếu không server sẽ từ chối khởi động.
SECRET_KEY=thay-bang-chuoi-bi-mat-that-ngau-nhien-toi-thieu-32-ky-tu
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- License ----
MAX_IPS_PER_KEY=3

# ---- CORS (danh sách origin của Frontend Vue, phân tách bằng dấu phẩy) ----
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
