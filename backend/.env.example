# Sao chép file này thành ".env" và chỉnh lại giá trị thật trước khi chạy.
# LƯU Ý: KHÔNG commit file .env thật lên git.

# ---- Môi trường: development | staging | production ----
ENVIRONMENT=development

# ---- Database ----
DATABASE_URL=sqlite:///./game_analytics.db

# ---- CORS (danh sách origin của Frontend được phép gọi API, phân tách bằng dấu phẩy) ----
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
